#!/bin/sh
# ABOUTME: Claude Code hook script that forwards events to the VibeFloor app.
# ABOUTME: Reads JSON from stdin, wraps it with CLAUDE_PROJECT_DIR, and POSTs to localhost.
INPUT=$(cat)
PORT_FILE="$HOME/Library/Caches/factoryfloor/hook-port"
[ -f "$PORT_FILE" ] || exit 0
PORT=$(cat "$PORT_FILE")
curl -s -X POST "http://127.0.0.1:${PORT}/hook" \
  -H "Content-Type: application/json" \
  -d "{\"event_input\": ${INPUT}, \"project_dir\": \"${CLAUDE_PROJECT_DIR}\"}" \
  --max-time 1 -o /dev/null 2>/dev/null
exit 0
